{
  "rewrites": [
    { "source": "/css/:path*", "destination": "/src/css/:path*" },
    { "source": "/js/:path*", "destination": "/src/js/:path*" },
    { "source": "/images/:path*", "destination": "/src/images/:path*" },
    { "source": "/", "destination": "/src/pages/index.html" },
    { "source": "/:page", "destination": "/src/pages/:page" }
  ],
  "headers": [
    {
      "source": "/(.*).(html|js|css)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    }
  ]
}
